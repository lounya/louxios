{
  "name": "louxios",
  "version": "1.0.0",
  "description": "Axios-based HTTP client with automatic cookie management, proxy support, and rate limiting",
  "license": "MIT",
  "keywords": [
    "axios",
    "cookie",
    "http-client",
    "cookie-jar",
    "proxy",
    "semaphore"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "axios": "^1.0.0"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "neverthrow": "^8.2.0",
    "socks-proxy-agent": "^8.0.5",
    "tough-cookie": "^6.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@types/node": "^25.3.5",
    "axios": "^1.13.6",
    "eslint": "^10.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
